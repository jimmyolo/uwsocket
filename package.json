{
  "name": "@jimmyolo/u-wsocket",
  "version": "2.1.8",
  "description": "☄️ WebSocket server, based on μWebSockets.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <23 || >=24 <25"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare": "npx husky",
    "test": "PORT=8888 node tests",
    "build": "node build.js",
    "clean": "rm -rf build dist",
    "release": "npx release-it --verbose",
    "release:dry": "pnpm release -- --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmyolo/u-wsocket.git"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "ultimate-ws": "^2.0.9",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.66.0"
  },
  "dependencies": {
    "tseep": "^1.3.1",
    "ws": "^8.20.0",
    "@jimmyolo/uws.js": "github:jimmyolo/uws.js#v20.66.0-alma.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil"
    ]
  }
}