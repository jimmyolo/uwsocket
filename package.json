{
  "name": "@jimmyolo/u-wsocket",
  "version": "2.0.1",
  "description": "☄️ WebSocket server, based on μWebSockets.js",
  "engines": {
    "node": ">=22 <23 || >=24 <25"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node tests",
    "build": "node build.js",
    "clean": "rm -rf build dist",
    "release": "npx release-it --verbose"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmyolo/u-wsocket.git"
  },
  "dependencies": {
    "tseep": "^1.3.1",
    "ws": "^8.20.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.63.0",
    "@jimmyolo/uws.js": "github:jimmyolo/uws.js#semver:^20.63.0-alma.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  }
}